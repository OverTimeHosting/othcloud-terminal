{
	"name": "othcloud-discord-presence",
	"displayName": "%displayName%",
	"description": "%description%",
	"version": "1.0.0",
	"publisher": "othcloud",
	"license": "MIT",
	"engines": {
		"vscode": "^1.5.0"
	},
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension",
	"scripts": {
		"compile": "gulp compile-extension:othcloud-discord-presence",
		"watch": "gulp watch-extension:othcloud-discord-presence"
	},
	"contributes": {
		"configuration": {
			"title": "OTHCloud Discord Presence",
			"properties": {
				"othcloud.discord.enabled": {
					"type": "boolean",
					"default": true,
					"description": "%config.enabled%"
				},
				"othcloud.discord.applicationName": {
					"type": "string",
					"default": "OTHCloud Terminal",
					"description": "%config.applicationName%"
				},
				"othcloud.discord.detailsTemplate": {
					"type": "string",
					"default": "Editing {file}",
					"description": "%config.detailsTemplate%"
				},
				"othcloud.discord.stateTemplate": {
					"type": "string",
					"default": "Workspace: {workspace} • {language}",
					"description": "%config.stateTemplate%"
				},
				"othcloud.discord.idleDetailsTemplate": {
					"type": "string",
					"default": "{app} — {idle}",
					"description": "%config.idleDetailsTemplate%"
				},
				"othcloud.discord.largeImage": {
					"type": "string",
					"default": "othcloud-logo",
					"description": "%config.largeImage%"
				},
				"othcloud.discord.largeImageText": {
					"type": "string",
					"default": "",
					"description": "%config.largeImageText%"
				},
				"othcloud.discord.smallImage": {
					"type": "string",
					"default": "",
					"description": "%config.smallImage%"
				},
				"othcloud.discord.smallImageText": {
					"type": "string",
					"default": "",
					"description": "%config.smallImageText%"
				},
				"othcloud.discord.idleText": {
					"type": "string",
					"default": "Idle",
					"description": "%config.idleText%"
				},
				"othcloud.discord.showFileName": {
					"type": "boolean",
					"default": true,
					"description": "%config.showFileName%"
				},
				"othcloud.discord.showWorkspace": {
					"type": "boolean",
					"default": true,
					"description": "%config.showWorkspace%"
				}
			}
		},
		"commands": [
			{
				"command": "othcloud.discord.showStatus",
				"title": "%cmd.showStatus%",
				"category": "OTHCloud Discord"
			},
			{
				"command": "othcloud.discord.reconnect",
				"title": "%cmd.reconnect%",
				"category": "OTHCloud Discord"
			}
		]
	},
	"devDependencies": {
		"@types/node": "22.x"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/vscode.git"
	}
}
